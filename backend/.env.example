# Copy to .env — never commit real secrets.
# TLS verification for live HTTP/TLS checks (0 only on trusted lab networks).
SCANNER_SSL_VERIFY=1

# --- CORS (comma-separated origins). Default includes local Vite + Docker UI.
# Required for browser calls from a deployed UI (e.g. Vercel): add that origin.
# SENTINEL_CORS_ORIGINS=http://localhost:5178,http://127.0.0.1:5178,https://your-app.vercel.app

# --- Trusted reverse proxies (comma-separated IPs or CIDRs).
# If empty, X-Forwarded-For is IGNORED (only the direct TCP peer IP is used).
# Example behind local nginx: SENTINEL_TRUSTED_PROXY_IPS=127.0.0.1,::1
# SENTINEL_TRUSTED_PROXY_IPS=10.0.0.0/8

# --- API keys (comma-separated). When SENTINEL_REQUIRE_API_KEY=1, all /api/* except
# /api/health require X-API-Key or Authorization: Bearer <key>.
# SENTINEL_REQUIRE_API_KEY=1
# SENTINEL_API_KEYS=your-long-random-secret

# --- Rate limit for POST /api/scans and POST /api/scheduled-scans/.../run (SlowAPI).
# SENTINEL_RATE_LIMIT=30/minute

# --- Delete scans older than N days (0 = disabled). Runs hourly.
# SENTINEL_RETENTION_DAYS=0

# --- OpenAI (optional) for POST /api/explain
# OPENAI_API_KEY=sk-proj-...

# --- Logging
# SENTINEL_LOG_LEVEL=INFO
